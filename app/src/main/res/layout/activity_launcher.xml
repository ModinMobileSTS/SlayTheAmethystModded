<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Initializing..."
            android:textSize="14sp" />

        <Button
            android:id="@+id/importButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Import desktop-1.0.jar" />

        <Button
            android:id="@+id/importModsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Import optional mods (.jar, multi-select)" />

        <Button
            android:id="@+id/importSavesButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Import saves zip" />

        <Button
            android:id="@+id/exportDebugButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Export debug logs (.zip)" />

        <TextView
            android:id="@+id/modsLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Enabled mods (BaseMod + StSLib are always required)"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/modsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/renderScaleLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Internal render scale (0.50 - 1.00)"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/renderScaleRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/renderScaleInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ems="6"
                android:hint="0.75"
                android:inputType="numberDecimal"
                android:maxLines="1"
                android:singleLine="true" />

            <Button
                android:id="@+id/saveRenderScaleButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Save" />
        </LinearLayout>

        <TextView
            android:id="@+id/rendererBackendLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/renderer_backend_label"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/rendererBackendSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/launchButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Launch STS (MTS + selected mods)" />

        <CheckBox
            android:id="@+id/backBehaviorCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:checked="true"
            android:text="Back key: immediate exit to main menu" />

        <TextView
            android:id="@+id/backBehaviorHintText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Unchecked = disable Back key while game is running."
            android:textSize="12sp" />

        <TextView
            android:id="@+id/logPathText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textIsSelectable="true"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
