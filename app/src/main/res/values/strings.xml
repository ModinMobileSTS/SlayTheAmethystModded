    <string name="heap_pressure_dialog_title">Consider increasing JVM heap</string>
    <string name="heap_pressure_dialog_message_recommend">This run peaked at about %1$d / %2$d MB of JVM heap (%3$d%%).\n\nIf you often see stutter or exits when many mods are enabled, consider raising the JVM heap max in Settings. The current heap max is %4$d MB; a reasonable next step is %5$d MB.</string>
